# Porta do servidor
PORT=8080
# Segredo do JWT (troque em produção)
JWT_SECRET=troque-este-segredo-em-producao
# Caminho do arquivo do banco SQLite
DB_PATH=./data/agency.db

# Publicação direta na Meta (Instagram/Facebook) — opcional.
# Crie um app em https://developers.facebook.com/apps e preencha:
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://seu-dominio.com.br/api/integrations/meta/callback
# Endereço público do sistema (a Meta precisa alcançar as artes):
PUBLIC_URL=https://seu-dominio.com.br
